# Cluster identity and topology.
CLUSTER_NAME="${CLUSTER_NAME:-mks}"
CONTROL_PLANES="${CONTROL_PLANES:-1}"
WORKERS="${WORKERS:-2}"

# Multipass launch settings. Ubuntu LTS images include AppArmor support.
IMAGE="${IMAGE:-24.04}"
CPUS="${CPUS:-2}"
MEMORY="${MEMORY:-4G}"
DISK="${DISK:-25G}"
MULTIPASS_LAUNCH_TIMEOUT="${MULTIPASS_LAUNCH_TIMEOUT:-1800}"

# Kubernetes package repository and version selection.
# KUBERNETES_MINOR selects https://pkgs.k8s.io/core:/stable:/v<minor>/deb/.
# KUBERNETES_VERSION=latest installs the latest patch in that minor.
KUBERNETES_MINOR="${KUBERNETES_MINOR:-1.35}"
KUBERNETES_VERSION="${KUBERNETES_VERSION:-${K8S_VERSION:-latest}}"

# kubeadm networking. Cilium is installed separately after bootstrap.
POD_CIDR="${POD_CIDR:-10.244.0.0/16}"
SERVICE_CIDR="${SERVICE_CIDR:-10.96.0.0/12}"
CONTROL_PLANE_ENDPOINT="${CONTROL_PLANE_ENDPOINT:-}"

# Local state written by the scripts.
STATE_DIR="${STATE_DIR:-.state}"
KUBECONFIG_PATH="${KUBECONFIG_PATH:-${STATE_DIR}/kubeconfig}"
